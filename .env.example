# Kalshi API credentials
KALSHI_API_KEY_ID=your-api-key-id-here
KALSHI_RSA_PRIVATE_KEY_PATH=./kalshi_private_key.pem

# Telegram credentials
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_CHAT_ID=your-telegram-chat-id-here

# Whale detection tuning (sniper mode)
WHALE_THRESHOLD_MULTIPLIER=25
ROLLING_WINDOW_SIZE=100
WHALE_MIN_DOLLAR_SIZE=50

# Trading settings
PORTFOLIO_RISK_FRACTION=0.15
MIN_TRADE_SIZE_CENTS=100
# Fixed dollar amount for paper copy trades (in cents, 1000 = $10)
PAPER_COPY_AMOUNT_CENTS=1000

# Bot behavior
POLL_INTERVAL_SECONDS=30
PAPER_TRADING=true

# Logging
TRADE_LOG_FILE=whale_trades.csv

# Market filter
MARKET_FILTER=WEATHER

# Morning report — sends daily summary at this time
MORNING_REPORT_HOUR=7
MORNING_REPORT_MINUTE=0
MORNING_REPORT_UTC_OFFSET=-4
